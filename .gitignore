# venv Python
.venv/

# Segredos e credenciais — NUNCA commitar
.env
# qualquer variante (.env.save, .env.local, .env.bak…) menos o exemplo versionado
.env.*
!.env.example
*.token
token.txt
configs/*.conf

# Dados sensíveis por natureza (mantém só o _EXAMPLE)
targets/*
!targets/_EXAMPLE
!targets/_EXAMPLE/**
loot/*
!loot/.gitkeep

# Achados rastreados — sensíveis; versiona só o exemplo
findings/*
!findings/_EXAMPLE
!findings/_EXAMPLE/**

# Estado operacional do loop (catálogo, baseline de escopo, boost por programa).
# Nasce git-ignored — nunca versionar escopo/score/IP da VPS.
state/

# Templates/padrões próprios — versiona só o README de cada dir
nuclei-templates/*
!nuclei-templates/README.md
gf-patterns/*
!gf-patterns/README.md

# Artefatos de recon que scripts geram dentro de subpastas
js_*/
src_app/
out_src/

# NOTA: vendored/claude-bug-bounty é um git SUBMODULE — é rastreado via
# .gitmodules + gitlink, não como arquivos. NÃO ignorar aqui.

# lixo
__pycache__/
*.pyc
.DS_Store
