# Sem aspas nos valores. Preencha direto após o = .

# === HackerOne API (bin/h1sync.py — Basic auth) ===
# H1_USER = seu USERNAME do HackerOne (o mesmo do curl -u username:token).
# H1_TOKEN = valor do API token (HackerOne > Settings > API Token).
H1_USER=
H1_TOKEN=

# === Atribuição (scripts da skill h1-program-kickoff) ===
# Handle que assina cada request de teste. Normalmente = seu username.
H1USER=
# Se algum programa exigir User-Agent == username em vez de header:
# BUA=

# === (opcional) recon mais profundo ===
CHAOS_API_KEY=

# === Discovery (bin/discover.py) ===
# Base raw do catálogo público (arkadiyt/bounty-targets-data).
BOUNTY_TARGETS_RAW=https://raw.githubusercontent.com/arkadiyt/bounty-targets-data/main/data
# Plataformas a descobrir (csv). Privado do H1 continua via h1sync.py.
DISCOVER_PLATFORMS=h1,bugcrowd,intigriti
# Quantos programas marcar tier_eligible (entram no loop de recon).
TOP_N=15
# Corte mínimo de score efetivo pra ser tier_eligible.
SCORE_MIN=0.0

# === Contenção de recon (Tier 2 / VPS 4 vCPU) ===
# Conservador por padrão: melhor lento que banido/derrubando a VPS.
NUCLEI_CONCURRENCY=25
NUCLEI_RATE_LIMIT=100
# Divide a lista em lotes; timeout de um lote preserva os achados parciais dele.
NUCLEI_BATCH_SIZE=25
TIER2_MAX_PER_BATCH=1800
# Teto GLOBAL de wall-clock do Tier 2 (todos os handles somados). Backstop pro
# pior caso ao escalar TOP_N — o teto-por-lote não limita o total. 0 = sem teto.
TIER2_MAX_TOTAL=21600
# Evita milhares de templates irrelevantes por host. Use 0 para todos.
NUCLEI_AUTOMATIC_SCAN=1
# info/low quase nunca viram report — foco no que importa pra bounty.
# Inclua low,info só se quiser varredura ampla (mais ruído, mais tempo).
NUCLEI_SEVERITY=medium,high,critical
# Usuário não-root que roda os systemd timers (deploy/systemd/install.sh).
# BBLAB_USER=bbhunter
# Caminhos extras para tools. O runner ja inclui ~/go/bin e ~/.local/bin.
# BBLAB_TOOL_PATH=/opt/projectdiscovery/bin:/outro/bin

# === (opcional) notificação — bin/notify.sh dispara em deltas do monitor ===
# Telegram: crie um bot com @BotFather (TG_BOT_TOKEN) e pegue seu chat_id (@userinfobot).
TG_BOT_TOKEN=
TG_CHAT_ID=
# Discord: Server Settings > Integrations > Webhooks > copie a URL.
DISCORD_WEBHOOK=
