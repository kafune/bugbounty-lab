# Sem aspas nos valores. Preencha direto após o = .

# === HackerOne API (bin/h1sync.py — Basic auth) ===
# H1_USER = seu USERNAME do HackerOne (o mesmo do curl -u username:token).
# H1_TOKEN = valor do API token (HackerOne > Settings > API Token).
H1_USER=
H1_TOKEN=

# === Atribuição (scripts da skill h1-program-kickoff) ===
# Handle que assina cada request de teste. Normalmente = seu username.
H1USER=
# Se algum programa exigir User-Agent == username em vez de header:
# BUA=

# === (opcional) recon mais profundo ===
CHAOS_API_KEY=
